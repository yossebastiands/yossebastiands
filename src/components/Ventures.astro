---
const ventures = [
  {
    name: "Modern Battle Operations",
    shortName: "MBO",
    category: "Game Development / Online Gaming",
    description:
      "A military-themed multiplayer FiveM game server delivering immersive tactical gameplay and a dedicated online community.",
  },
  {
    name: "Apollo Flight Program",
    shortName: "AFP",
    category: "Software Development / Game Tooling",
    description:
      "A creative studio producing FiveM scripts, tools, and assets — from combat systems to immersive vehicle mechanics.",
  },
  {
    name: "Opventra",
    shortName: "OPV",
    category: "SaaS / Productivity Software",
    description:
      "A consulting and template product studio focused on workflow automation and Google Sheets systems for modern teams.",
  },
];
---

<section class="px-6 py-20 max-w-5xl mx-auto">
  <h2 class="text-xs font-semibold tracking-widest uppercase text-orange-500 mb-8">
    Ventures
  </h2>
  <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {
      ventures.map((v) => (
        <div class="bg-[#111] rounded-2xl p-6 flex flex-col gap-3 border border-white/5 hover:border-orange-500/30 transition-colors">
          <div class="flex items-start justify-between gap-3">
            <h3 class="text-white font-semibold text-base leading-snug">{v.name}</h3>
            <span class="shrink-0 text-[10px] font-bold tracking-wider text-orange-500 bg-orange-500/10 rounded-full px-2.5 py-1 mt-0.5">
              {v.shortName}
            </span>
          </div>
          <p class="text-[11px] font-medium text-gray-500 uppercase tracking-wider">
            {v.category}
          </p>
          <p class="text-gray-400 text-sm leading-relaxed">{v.description}</p>
        </div>
      ))
    }
  </div>
</section>
