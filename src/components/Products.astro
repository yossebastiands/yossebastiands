---
const products = [
  {
    name: "HSTF Intel Dashboard",
    description:
      "A Google Apps Script–based roleplay management web app for tracking operations, personnel, and unit intelligence. Available on Tebex.",
    venture: "AFP",
    link: null,
  },
  {
    name: "Afterburner Effect Script",
    description:
      "A FiveM fighter jet afterburner effect script that brings immersive visual and audio effects to aerial combat roleplay.",
    venture: "AFP",
    link: null,
  },
  {
    name: "AFP Handlings",
    description:
      "GTA V vehicle handling packs and a custom tuning service, crafted for realism and performance in FiveM environments.",
    venture: "AFP",
    link: null,
  },
  {
    name: "Change Request Template System",
    description:
      "A Google Forms and Sheets–based workflow template for streamlined change management processes. Available on Gumroad and Etsy.",
    venture: "Opventra",
    link: null,
  },
];
---

<section class="px-6 py-20 max-w-5xl mx-auto">
  <h2 class="text-xs font-semibold tracking-widest uppercase text-orange-500 mb-8">
    Products
  </h2>
  <div class="grid gap-5 sm:grid-cols-2">
    {
      products.map((p) => (
        <div class="bg-[#111] rounded-2xl p-6 flex flex-col gap-3 border border-white/5 hover:border-orange-500/30 transition-colors">
          <div class="flex items-start justify-between gap-3">
            <h3 class="text-white font-semibold text-base leading-snug">{p.name}</h3>
            <span class="shrink-0 text-[10px] font-bold tracking-wider text-orange-500 bg-orange-500/10 rounded-full px-2.5 py-1 mt-0.5">
              {p.venture}
            </span>
          </div>
          <p class="text-gray-400 text-sm leading-relaxed">{p.description}</p>
        </div>
      ))
    }
  </div>
</section>
